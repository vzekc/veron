[Unit]
Description=VERON 3270 Terminal Application
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=veron
Group=veron
WorkingDirectory=/opt/veron
EnvironmentFile=/etc/veron/env
ExecStartPre=/bin/bash -c 'rm -rf /home/veron/.cache/common-lisp/*/opt/veron/lispf'
ExecStart=/usr/bin/sbcl --non-interactive \
    --load /home/veron/quicklisp/setup.lisp \
    --load load.lisp \
    --eval '(veron:start-from-env)'
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=veron

[Install]
WantedBy=multi-user.target
