(:name "set-password-otp"
 :overlay (17 19)
 :start-row 17
 :screen "

   Neues Passwort:
   Wiederholen:
"
 :fields ((:from (18 20) :len 59 :name new-password :write t :hidden t :transient t)
          (:from (19 20) :len 59 :name confirm-password :write t :hidden t :transient t))
 :keys ((:enter "Speichern")
        (:pf3 "Abmelden")))
