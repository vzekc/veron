(:name "set-password"
 :navigable t
 :screen "

   Lokales Passwort setzen

   Das lokale Passwort wird fuer unverschluesselte
   Verbindungen verwendet. Bitte verwende ein Passwort,
   das Du nirgendwo anders benutzt.

   Neues Passwort:
   Wiederholen:
"
 :fields ((:from (7 20) :len 59 :name new-password :write t :hidden t :transient t)
          (:from (8 20) :len 59 :name confirm-password :write t :hidden t :transient t))
 :keys ((:enter "Speichern")
        (:pf3 "Zurueck")))
